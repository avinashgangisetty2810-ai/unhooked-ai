# Copy to .streamlit/secrets.toml and fill in your keys.
# On Streamlit Community Cloud, paste these into App settings -> Secrets.

# Primary provider (required) — free key at https://console.groq.com
GROQ_API_KEY = "gsk_your_key_here"

# Optional fallback provider — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY = ""

# Optional model overrides
# GROQ_MODEL = "llama-3.3-70b-versatile"
# GEMINI_MODEL = "gemini-2.5-flash"
